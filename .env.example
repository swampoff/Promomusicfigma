# ══════════════════════════════════════════════════════
# ПРОМО.МУЗЫКА — Environment Variables
# ══════════════════════════════════════════════════════

# ── Supabase ──
VITE_SUPABASE_PROJECT_ID=your-project-id-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── ЮКасса (основной платёжный шлюз, РФ) ──
# Панель управления: https://yookassa.ru/my
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── Т-Банк Эквайринг (альтернативный, РФ) ──
# Панель управления: https://business.tbank.ru/
TBANK_TERMINAL_KEY=
TBANK_SECRET_KEY=

# ── Stripe (международные платежи) ──
# Панель управления: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Платёжные вебхуки ──
# Base URL для webhook-ов (Supabase Edge Functions)
PAYMENT_WEBHOOK_BASE_URL=https://your-project.supabase.co/functions/v1/server

# ── Cron (автопродление подписок) ──
CRON_SECRET=

# ── VPS / 152-ФЗ ──
VPS_USERDATA_URL=https://mail.promofm.org/userdata
VPS_INTERNAL_KEY=
